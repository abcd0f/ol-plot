{
  "name": "@seedlib/ol-plot",
  "version": "1.0.2",
  "description": "OpenLayers plotting library",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev:docs": "pnpm -F @ol-plot/docs run dev",
    "build": "pnpm run build:esm && pnpm run build:iife",
    "build:esm": "tsdown --config tsdown.config.ts",
    "build:iife": "tsdown --config tsdown.iife.config.ts",
    "lint": "pnpm run lint",
    "format": "pnpm run format",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format:write": "prettier --write \"src/**/*.{ts,js}\"",
    "clean": "node ./scripts/clean.mjs",
    "pub": "npm publish --access public"
  },
  "keywords": [
    "openlayers",
    "ol",
    "gis",
    "plot",
    "measure",
    "draw"
  ],
  "author": "wlt",
  "license": "ISC",
  "homepage": "https://github.com/abcd0f/ol-plot",
  "repository": {
    "type": "git",
    "url": "https://github.com/abcd0f/ol-plot.git"
  },
  "bugs": {
    "url": "https://github.com/abcd0f/ol-plot/issues"
  },
  "packageManager": "pnpm@10.28.2",
  "peerDependencies": {
    "ol": ">=10.8.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
